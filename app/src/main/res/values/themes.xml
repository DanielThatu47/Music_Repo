<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MusicPlayer" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/spotify_green</item>
        <item name="colorPrimaryVariant">@color/spotify_green_dark</item>
        <item name="colorOnPrimary">@color/spotify_black</item>
        <item name="colorSecondary">@color/spotify_green</item>
        <item name="colorOnSecondary">@color/spotify_black</item>
        <item name="colorSurface">@color/spotify_dark_bg</item>
        <item name="colorOnSurface">@color/spotify_white</item>
        <item name="android:colorBackground">@color/spotify_dark_bg</item>
        <item name="android:windowBackground">@color/spotify_dark_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/spotify_black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.MusicPlayer.Splash" parent="Theme.MusicPlayer">
        <item name="android:windowBackground">@color/spotify_black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Widget.MusicPlayer.Button.Spotify" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/spotify_green</item>
        <item name="android:textColor">@color/spotify_black</item>
        <item name="cornerRadius">50dp</item>
    </style>

</resources>
